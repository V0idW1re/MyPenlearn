{
  "productName": "penlearn-local",
  "version": "0.1.20",
  "identifier": "ai.penlearn.local",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Penlearn Local",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "deb",
    "icon": [
      "icons/icon.png"
    ],
    "resources": [],
    "externalBin": [],
    "linux": {
      "deb": {
        "desktopTemplate": "penlearn-local.desktop",
        "postInstallScript": "scripts/post-install.sh",
        "preRemoveScript": "scripts/pre-remove.sh",
        "files": {
          "/usr/lib/penlearn-local/mcp-server/pyproject.toml": "../mcp-server/pyproject.toml",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/__init__.py": "../mcp-server/penlearn_mcp/__init__.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/__main__.py": "../mcp-server/penlearn_mcp/__main__.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/db.py": "../mcp-server/penlearn_mcp/db.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/__init__.py": "../mcp-server/penlearn_mcp/tools/__init__.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/_cache.py": "../mcp-server/penlearn_mcp/tools/_cache.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/_helpers.py": "../mcp-server/penlearn_mcp/tools/_helpers.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/binary.py": "../mcp-server/penlearn_mcp/tools/binary.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/cloud.py": "../mcp-server/penlearn_mcp/tools/cloud.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/crypto.py": "../mcp-server/penlearn_mcp/tools/crypto.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/execute.py": "../mcp-server/penlearn_mcp/tools/execute.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/exploit.py": "../mcp-server/penlearn_mcp/tools/exploit.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/findings.py": "../mcp-server/penlearn_mcp/tools/findings.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/guardrails.py": "../mcp-server/penlearn_mcp/tools/guardrails.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/htb_machines.py": "../mcp-server/penlearn_mcp/tools/htb_machines.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/network.py": "../mcp-server/penlearn_mcp/tools/network.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/osint.py": "../mcp-server/penlearn_mcp/tools/osint.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/passwords.py": "../mcp-server/penlearn_mcp/tools/passwords.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/plan.py": "../mcp-server/penlearn_mcp/tools/plan.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/post_exploit.py": "../mcp-server/penlearn_mcp/tools/post_exploit.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/recon.py": "../mcp-server/penlearn_mcp/tools/recon.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/register_all.py": "../mcp-server/penlearn_mcp/tools/register_all.py",
          "/usr/lib/penlearn-local/scripts/agent-guard.py": "../scripts/agent-guard.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/report.py": "../mcp-server/penlearn_mcp/tools/report.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/scanner.py": "../mcp-server/penlearn_mcp/tools/scanner.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/utils.py": "../mcp-server/penlearn_mcp/tools/utils.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/web.py": "../mcp-server/penlearn_mcp/tools/web.py",
          "/usr/lib/penlearn-local/mcp-server/penlearn_mcp/tools/workspace.py": "../mcp-server/penlearn_mcp/tools/workspace.py"
        }
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
